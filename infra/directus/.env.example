## Directus secrets (change for real deployments)
DIRECTUS_KEY=replace-me-with-random-key
DIRECTUS_SECRET=replace-me-with-random-secret

## First-run admin bootstrap
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me-now

## CORS
# Local dev (Vite + nginx)
DIRECTUS_CORS_ORIGIN=http://localhost:5173,http://localhost

## Public URL
DIRECTUS_PUBLIC_URL=http://localhost:8055

## Optional GitHub OAuth (configure GitHub app + Directus provider settings)
DIRECTUS_AUTH_PROVIDERS=
DIRECTUS_AUTH_GITHUB_CLIENT_ID=
DIRECTUS_AUTH_GITHUB_CLIENT_SECRET=

